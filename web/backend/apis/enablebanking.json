{
  "openapi": "3.0.0",
  "info": {
    "title": "Enable Banking API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.enablebanking.com"
    }
  ],
  "paths": {
    "/aspsps": {
      "get": {
        "operationId": "get_aspsps",
        "parameters": [
          { "name": "country", "in": "query", "schema": { "type": "string" } },
          {
            "name": "psu_type",
            "in": "query",
            "schema": { "type": "string", "enum": ["personal", "business"] }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "aspsps": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ASPSP" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth": {
      "post": {
        "operationId": "start_authorization",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "access": {
                    "type": "object",
                    "properties": {
                      "valid_until": { "type": "string", "format": "date-time" }
                    }
                  },
                  "aspsp": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "country": { "type": "string" }
                    }
                  },
                  "state": { "type": "string" },
                  "redirect_url": { "type": "string" },
                  "psu_id": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": { "type": "string" },
                    "authorization_id": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sessions": {
      "post": {
        "operationId": "create_session",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "session_id": { "type": "string" },
                    "accounts": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AccountReference"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}": {
      "get": {
        "operationId": "get_session",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "session_id": { "type": "string" },
                    "status": { "type": "string" },
                    "accounts": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AccountReference"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/details": {
      "get": {
        "operationId": "get_account_details",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Account" }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/balances": {
      "get": {
        "operationId": "get_account_balances",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "balances": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Balance" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}/transactions": {
      "get": {
        "operationId": "get_account_transactions",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "date_from",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "date_to",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "continuation_key",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactions": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Transaction" }
                    },
                    "continuation_key": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ASPSP": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "country": { "type": "string" },
          "bic": { "type": "string" }
        }
      },
      "AccountReference": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "uid": { "type": "string" }
            }
          }
        ]
      },
      "Account": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "iban": { "type": "string" },
          "currency": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Balance": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "balance_amount": { "$ref": "#/components/schemas/Amount" },
          "reference_date": { "type": "string", "format": "date" }
        }
      },
      "Amount": {
        "type": "object",
        "properties": {
          "amount": { "type": "string" },
          "currency": { "type": "string" }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "transaction_id": { "type": "string" },
          "entry_reference": { "type": "string" },
          "status": { "type": "string" },
          "transaction_amount": { "$ref": "#/components/schemas/Amount" },
          "booking_date": { "type": "string", "format": "date" },
          "value_date": { "type": "string", "format": "date" },
          "credit_debit_indicator": { "type": "string" },
          "remittance_information": {
            "type": "array",
            "items": { "type": "string" }
          },
          "creditor": { "$ref": "#/components/schemas/Counterparty" },
          "debtor": { "$ref": "#/components/schemas/Counterparty" }
        }
      },
      "Counterparty": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "account": {
            "type": "object",
            "properties": {
              "iban": { "type": "string" }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [{ "bearerAuth": [] }]
}
